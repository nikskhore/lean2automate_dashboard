# Copy this file to `.env` and fill in real values.

# --- Database (PostgreSQL / Supabase) ---
# Use your Supabase "Session pooler" connection string (port 5432 — supports Prisma migrations).
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI (Session pooler).
# Format: postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.<ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
# Use a long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=4000
# Comma-separated list of allowed web origins for CORS (must match the web dev server port)
CORS_ORIGIN="http://localhost:5180"

# --- File storage ---
# local = disk (dev).  s3 = S3-compatible bucket (Cloudflare R2 / Supabase Storage) for production.
STORAGE_DRIVER="local"
# Directory (relative to backend/) where uploaded receipts are written when STORAGE_DRIVER=local
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=10

# Required only when STORAGE_DRIVER=s3:
# Cloudflare R2:  S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com  S3_REGION=auto
# Supabase:       S3_ENDPOINT=https://<ref>.storage.supabase.co/storage/v1/s3  S3_REGION=<project-region>
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional public URL prefix if the bucket is public (otherwise files stream via the API)
S3_PUBLIC_URL=""

# --- Recurring cron (production) ---
# Set a random secret to enable POST /api/internal/run-recurring for a scheduled trigger.
CRON_SECRET=""
# Set to false on the API host if an external cron (Cloudflare) drives recurring instead of the in-process one.
ENABLE_CRON="true"

# --- App defaults ---
DEFAULT_CURRENCY="INR"
